# Required for /api/llm (OpenAI Chat Completions)
# - Local: copy to .env.local and run `npm run dev` (starts scripts/dev-api.mjs + Vite)
# - Vercel: set in Project → Settings → Environment Variables
OPENAI_API_KEY=

# Optional — default gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional — local dev API port (default 8787). If you change it, also set for Vite:
# DEV_API_PORT=8788
# DEV_API_URL=http://127.0.0.1:8788

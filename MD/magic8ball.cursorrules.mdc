  data/
    responses.ts       # Fallback static lines (keep — used on API failure)
    memes.ts           # Meme filename list
  orchestration/
    messageRouter.ts   # Decides which character handler to call
    globalCounter.ts   # Tracks total user message count (every-4th logic)
    callFlow.ts        # Incoming call popup + group chat unlock state
  hooks/
    useChat.ts
    useCallFlow.ts
  components/          # UI only — no business logic
  assets/audio/        # Sound files (ringtone, new message ping)
public/
  memes/               # meme1.png … meme30.png
```

